#!/bin/bash
set -e

API_PORT=8080
if [ ! -z "$PORT" ]; then
    API_PORT="$PORT"
fi

python - "$API_PORT" <<'PY'
import sys
from waitress.runner import run

api_port = sys.argv[1]
sys.argv = [
    'waitress-serve',
    '--listen=0.0.0.0:{}'.format(api_port),
    'air_pollution.api.air_app:pandasApi',
]
run()
PY
